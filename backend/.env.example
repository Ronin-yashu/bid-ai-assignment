# Database
DATABASE_URL=postgresql://user:password@localhost:5432/ysp_db

# JWT
JWT_SECRET=your_super_secret_key_here_min_32_chars
JWT_EXPIRES_IN=7d

# Server
PORT=5000
NODE_ENV=development

# CORS — set to your frontend URL
FRONTEND_URL=http://localhost:5173

# Admin account creation secret (used with POST /api/auth/register-admin)
ADMIN_SECRET=your_admin_secret_here

# Production values (set in Render dashboard, do not commit)
# DATABASE_URL=postgresql://...render...internal...
# FRONTEND_URL=https://bid-ai-assignment.vercel.app
# NODE_ENV=production
